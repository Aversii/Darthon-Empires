{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "migration": "dotenv -e .env.local -- kysely migrate make",
    "migrate": "dotenv -e .env.local -- bash -c \"kysely migrate latest && kysely-codegen --out-file src/db/generated/schema.ts\"",
    "codegen": "dotenv -e .env.local -- kysely-codegen --out-file src/db/generated/schema.ts",
    "rollback": "dotenv -e .env.local -- kysely migrate rollback --all"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "kysely": "0.28.14",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "dotenv-cli": "^11.0.0",
    "kysely-codegen": "^0.18.5",
    "kysely-ctl": "^0.14.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
